    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.1",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "make-coverage-badge": "1.2.0",
    "prettier": "3.8.1",
    "prettier-eslint": "16.4.2",
    "ts-jest": "29.4.9",
    "ts-jest-resolver": "2.0.1",
    "typescript": "6.0.2"
